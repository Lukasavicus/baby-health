# Backend API (FastAPI). Used by src/api/client.ts for UI bootstrap and seeds.
# Use 127.0.0.1 to avoid macOS localhost (::1) vs IPv4 listener mismatches (connection reset).
VITE_API_BASE_URL=http://127.0.0.1:8080
# Demo JSON: start API with BABYHEALTH_USE_UI_SEED=1 (see repo root npm run dev-api-seed).
# To use a different JSON folder, set DATA_DIR on the API process (e.g. backend/data/davi_test).

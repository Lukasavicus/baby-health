# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
venv/
.env

# Node
node_modules/
.next/
out/
build/
.env.local
.env.development.local
.env.test.local
.env.production.local
npm-debug.log*

# Data (local runtime; versioned UI defaults live in backend/ui_app_defaults/)
backend/data/*.json
!backend/data/users.json
!backend/data/.gitkeep
!backend/ui_app_defaults/**/*.json
# Uploaded profile images (keep folder placeholders only)
backend/data/**/images/*
!backend/data/**/images/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Credentials (never commit service-account keys)
INPUTS/baby-health-492304-2ba759213009.json

# INPUTS/ -- reference materials; tracked intentionally in development

# Misc
*.log

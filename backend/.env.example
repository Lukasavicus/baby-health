# BabyHealth API Configuration

# App settings
APP_NAME=BabyHealth API
APP_VERSION=1.0.0
DEBUG=True

# Storage
STORAGE_TYPE=json
DATA_DIR=./data

# JWT Authentication
JWT_SECRET=change-me-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# CORS
# Comma-separated, or JSON array on one line. No "*" with credentials.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:8080

# Built SPA directory (default: repo-root/frontend/dist). Use ../app-design/dist for the new UI bundle.
# FRONTEND_DIST_DIR=../app-design/dist

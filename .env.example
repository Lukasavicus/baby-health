# BabyHealth Environment Configuration
# Copy this file to .env and update values for your environment

# Application Settings
DEBUG=false
ENVIRONMENT=production

# Server Configuration
PORT=8080
HOST=0.0.0.0

# Storage Configuration (JSON store root: babies.json, events.json, …)
STORAGE_TYPE=json
DATA_DIR=./backend/data
# Example alternate dataset: DATA_DIR=./backend/data/davi_test
# Per profile: uploads go to DATA_DIR/images/ (10 MiB/file, 1 GiB total; see POST /api/media/upload)

# UI demo defaults (catalogs, bootstrap JSON). When enabled, files are read from backend/ui_app_defaults/
# BABYHEALTH_USE_UI_SEED=1
# Optional override of the defaults directory (path to folder containing *.json):
# BABYHEALTH_UI_DEFAULTS_DIR=./backend/ui_app_defaults

# Built SPA served by FastAPI (default: <repo>/frontend/dist). Example for app-design:
# FRONTEND_DIST_DIR=./app-design/dist

# CORS: comma-separated origins (do not use JSON brackets here — config parses CSV or JSON array)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://127.0.0.1:5173,http://127.0.0.1:8080,https://yourdomain.com

# Google Cloud Configuration
GCP_PROJECT_ID=baby-health-app
GCP_REGION=us-central1

# Logging
LOG_LEVEL=INFO

# Feature flags (optional module). Copy to .env and set TOTP secret (openssl rand -base32 20).
# FEATURE_FLAGS_ENABLED=1
# FEATURE_FLAGS_TOTP_SECRET=
# FEATURE_FLAGS_STORE_PATH=

# BabyHealth API Configuration

# App settings
APP_NAME=BabyHealth API
APP_VERSION=1.0.0
DEBUG=True

# Onboarding: mock email code 123456 is allowed when DEBUG=True OR when set below
# BABYHEALTH_ALLOW_MOCK_EMAIL_CODE=1

# Storage
STORAGE_TYPE=json
DATA_DIR=./data

# JWT Authentication
JWT_SECRET=change-me-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:5173,*

# Built SPA directory (default: repo-root/frontend/dist). Use ../app-design/dist for the new UI bundle.
# FRONTEND_DIST_DIR=../app-design/dist
